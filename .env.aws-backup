# --- AWS creds (Workshop Studio temp; ASIA prefix = expires in ~1-4h) ---
# Re-grab from the "Get AWS CLI credentials" button when test-bedrock
# returns ExpiredToken. All three values change on refresh.
AWS_ACCESS_KEY_ID=ASIAYO4RYSQHCQ23MBHO
AWS_SECRET_ACCESS_KEY=SDbEW8tgOa1LIqG3E/bMVBekSuvm2ReF6dKMnkPV
AWS_SESSION_
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# --- Bedrock (real mode) ---
# us. prefix = cross-region inference profile, required for Sonnet 4.5.
BEDROCK_MODE=real
BEDROCK_REGION=us-east-1
BEDROCK_TEXT_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# Per-task models — Sonnet for cheap routine work, Opus for judgment quality.
# Each defaults to BEDROCK_TEXT_MODEL if unset.
BEDROCK_ANALYZER_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_ORCHESTRATOR_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_RECOMMENDER_MODEL=us.anthropic.claude-opus-4-5-20251101-v1:0
BEDROCK_VERIFIER_MODEL=us.anthropic.claude-opus-4-5-20251101-v1:0

# --- Vector store (already wired) ---
VECTOR_MODE=aoss
AOSS_ENDPOINT=https://eja7umnxrfag2z06acbd.us-east-1.aoss.amazonaws.com

# --- Event tier (already wired) ---
EVENT_PROCESSING_MODE=full
SESSION_FLUSH_THRESHOLD=3

# --- Future toggles (factories not built yet — no-op today) ---
SUPERVISOR_MODE=manual
RECOMMEND_MODE=strands
PII_MODE=comprehend
TRACE_SYNC_MODE=s3
S3_TRACES_BUCKET=hyperpersona-traces-5817368955
AGENTCORE_AGENT_ARN=arn:aws:bedrock-agentcore:us-east-1:581736895502:runtime/hyperpersona_analyzer-pwmKcVD2hR

# Job queue — redis (Docker container) or sqs (real AWS-managed).
QUEUE_MODE=sqs
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/581736895502/hyperpersona-jobs

# --- Existing infra ---
REDIS_URL=redis://localhost:6379
# Empty = real AWS DynamoDB. http://localhost:8001 = DynamoDB Local container.
DYNAMODB_ENDPOINT=
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
API_KEY=test-key
